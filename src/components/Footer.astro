---
// Site footer — three columns + full-width disclaimer
---
<footer class="px-6 sm:px-10 pt-16 pb-10 border-t border-black/5 mt-16">
  <div class="max-w-6xl mx-auto">

    <!-- ── Top row: logo + 3 columns ── -->
    <div class="grid grid-cols-1 sm:grid-cols-4 gap-10 sm:gap-12 mb-12">

      <!-- Brand block -->
      <div class="sm:col-span-1">
        <div class="inline-flex items-center gap-2 mb-3">
          <span class="w-6 h-6 rounded-md bg-accent flex items-center justify-center">
            <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" aria-hidden="true">
              <path d="M12 2L12 14M12 14L8 10M12 14L16 10M4 18H20"
                stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none" />
            </svg>
          </span>
          <span class="font-serif text-xl font-semibold tracking-tight text-ink">Arrivly</span>
        </div>
        <p class="text-sm text-muted leading-relaxed max-w-[14rem]">
          Because the first weeks are hard enough.
        </p>
      </div>

      <!-- Compare -->
      <div>
        <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-faint mb-4">Compare</p>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/sim-cards" class="text-ink hover:text-muted transition-colors">SIM cards</a></li>
          <li><span class="text-faint">Health insurance <span class="text-[10px] ml-1">Coming soon</span></span></li>
          <li><span class="text-faint">Bank accounts <span class="text-[10px] ml-1">Coming soon</span></span></li>
          <li><span class="text-faint">Money transfer <span class="text-[10px] ml-1">Coming soon</span></span></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-faint mb-4">Company</p>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/about" class="text-ink hover:text-muted transition-colors">About</a></li>
          <li><a href="mailto:hello@arrivly.com.au" class="text-ink hover:text-muted transition-colors">Contact</a></li>
          <li><a href="/affiliate-disclosure" class="text-ink hover:text-muted transition-colors">Affiliate disclosure</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-faint mb-4">Legal</p>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/privacy" class="text-ink hover:text-muted transition-colors">Privacy policy</a></li>
          <li><a href="/terms" class="text-ink hover:text-muted transition-colors">Terms of use</a></li>
          <li><span class="text-faint">Data verified: May 2026</span></li>
        </ul>
      </div>

    </div>

    <!-- ── Bottom disclaimer ── -->
    <div class="pt-8 border-t border-black/5">
      <p class="text-xs text-faint leading-relaxed max-w-4xl">
        Arrivly is not a financial adviser, insurance broker, or migration agent. Information on this site is general in nature.
        Always verify plan details with the provider before purchasing. Some links earn us a commission — this does not affect our recommendations.
        <span class="block mt-2">© 2026 Arrivly. All rights reserved.</span>
      </p>
    </div>

  </div>
</footer>
