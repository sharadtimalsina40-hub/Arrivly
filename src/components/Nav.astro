---
// Nav header — used on every page. Logo links to /. Inline nav exposes live tools.
---
<header class="px-6 sm:px-10 py-6">
  <div class="max-w-6xl mx-auto flex items-center justify-between gap-4">
    <a href="/" class="inline-flex items-center gap-2 group shrink-0">
      <span class="w-6 h-6 rounded-md bg-accent flex items-center justify-center group-hover:scale-105 transition-transform">
        <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" aria-hidden="true">
          <path d="M12 2L12 14M12 14L8 10M12 14L16 10M4 18H20"
            stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none" />
        </svg>
      </span>
      <span class="font-serif text-xl font-semibold tracking-tight text-ink">Arrivly</span>
    </a>

    <nav class="hidden sm:flex items-center gap-6 text-sm">
      <a href="/sim-cards" class="text-muted hover:text-ink transition-colors">SIM cards</a>
      <a href="/health-insurance" class="text-muted hover:text-ink transition-colors">Health insurance</a>
      <a href="/blog" class="text-muted hover:text-ink transition-colors">Blog</a>
    </nav>
  </div>
</header>
